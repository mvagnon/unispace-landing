---
import { type CollectionEntry, getCollection } from "astro:content";
import CtaCardBgImage from "@/components/cta/CtaCardBgImage.astro";
import FaqAccordions from "@/components/faq/FaqAccordions.astro";
import FeatureCardsSmall from "@/components/feature/FeatureCardsSmall.astro";
import FeatureLightboxMarquee from "@/components/feature/FeatureLightboxMarquee.astro";
import FeatureSteps from "@/components/feature/FeatureSteps.astro";
import HeroDownload from "@/components/hero/HeroDownload.astro";
import PricingThreeCards from "@/components/pricing/PricingThreeCards.astro";
import { filterCollectionByLanguage, getLocaleFromUrl } from "@/js/localeUtils";
import { getTranslatedData } from "@/js/translationUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

const landingEntries = await getCollection("landing");
const filtered = filterCollectionByLanguage(landingEntries, "fr");
const data = filtered[0]!.data;
---

<BaseLayout title={siteData.title} description={siteData.description} navStyle="default">
  <HeroDownload title={data.heroTitle} description={data.heroDescription} />

  <FeatureCardsSmall
    badge="Fonctionnalités"
    title="Tout ce dont vous avez besoin dans une seule app"
    description="Unispace rassemble les outils que vous utilisez au quotidien."
    features={data.features}
  />

  <FeatureSteps
    title={data.stepsTitle}
    steps={data.steps}
    buttonText="Télécharger"
    buttonHref="#hero-download"
  />

  <!-- <FeatureLightboxMarquee
    badge="Galerie"
    title={data.galleryTitle}
    description={data.galleryDescription}
  /> -->

  <PricingThreeCards title={data.pricingTitle} plans={data.pricingPlans} currency="€" />

  <CtaCardBgImage
    title={data.ctaTitle}
    description={data.ctaDescription}
    buttonText={data.ctaButtonText}
    buttonHref="#hero-download"
  />

  <FaqAccordions
    title="Questions fréquentes"
    description="Retrouvez les réponses aux questions les plus courantes sur Unispace"
    faqItems={data.faq}
  />
</BaseLayout>
