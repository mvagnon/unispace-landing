---
import SiteLogo from "@/components/site-logo/SiteLogo.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getTranslatedData } from "@/js/translationUtils";
import FooterLink from "./FooterLink.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
const today = new Date();

const footerContent = {
  en: {
    description:
      "All your productivity tools, unified in one distraction-free desktop workspace. Available on Windows and macOS.",
    columns: [
      {
        title: "Product",
        links: [
          { label: "Features", href: "/#feature-cards-small" },
          { label: "Pricing", href: "/#pricing-three-cards" },
          { label: "FAQ", href: "/#faq-accordions" },
          { label: "Download", href: "/#hero-download" },
        ],
      },
      // {
      //   title: "Legal",
      //   links: [
      //     { label: "Privacy Policy", href: "/privacy-policy" },
      //     { label: "Terms of Use", href: "/terms" },
      //   ],
      // },
    ],
    copyright: "All Rights Reserved",
  },
  fr: {
    description:
      "Tous vos outils de productivité, unifiés dans un espace de travail desktop sans distraction. Disponible sur Windows et macOS.",
    columns: [
      {
        title: "Produit",
        links: [
          { label: "Fonctionnalités", href: "/#feature-cards-small" },
          { label: "Tarifs", href: "/#pricing-three-cards" },
          { label: "FAQ", href: "/#faq-accordions" },
          { label: "Télécharger", href: "/#hero-download" },
        ],
      },
      // {
      //   title: "Légal",
      //   links: [
      //     { label: "Politique de confidentialité", href: "/privacy-policy" },
      //     { label: "Conditions d'utilisation", href: "/terms" },
      //   ],
      // },
    ],
    copyright: "Tous droits réservés",
  },
} as const;

const content = footerContent[currLocale];
---

<section class="overflow-hidden pt-16 pb-10">
  <div class="site-container">
    <div class="border-b pb-16">
      <div class="-m-8 flex flex-wrap">
        <div class="w-full p-8 sm:w-1/2 lg:w-6/12">
          <div class="lg:max-w-sm">
            <SiteLogo />
            <p class="text-muted-foreground mt-4 font-medium md:max-w-xs">
              {content.description}
            </p>
          </div>
        </div>
        {
          content.columns.map((col) => (
            <div class="w-full p-8 sm:w-1/2 lg:w-3/12" aria-label={col.title}>
              <h3 class="font-heading mb-8 text-sm font-medium uppercase">{col.title}</h3>
              <ul class="space-y-2">
                {col.links.map((link) => (
                  <FooterLink label={link.label} href={link.href} />
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <p class="text-muted-foreground py-5 text-center text-sm leading-normal font-medium">
      Copyright {today.getFullYear()}
      {siteData.name}. {content.copyright}
    </p>
  </div>
</section>
