---
/**
 * Hero section with OS-aware download button and platform links.
 */

import { Icon } from "astro-icon/components";
import Button from "@/components/button/Button.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { useTranslations } from "@/js/translationUtils";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);

const macUrl =
  "https://github.com/SoluDevTech/unispace-releases/releases/latest/download/Unispace-mac.dmg";
const winUrl =
  "https://github.com/SoluDevTech/unispace-releases/releases/latest/download/Unispace-win.exe";
---

<section id="download" class="relative mt-14 overflow-x-clip">
  <!-- Backdrop Grid Pattern -->
  <div class="text-foreground absolute inset-0" aria-hidden="true">
    <svg class="absolute h-full w-full opacity-8" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="1.5"></path>
        </pattern>
        <radialGradient id="oval-fade" cx="50%" cy="50%" r="40%" fx="50%" fy="50%">
          <stop offset="0%" stop-color="white" stop-opacity="1"></stop>
          <stop offset="40%" stop-color="white" stop-opacity="0.7"></stop>
          <stop offset="70%" stop-color="white" stop-opacity="0.3"></stop>
          <stop offset="100%" stop-color="white" stop-opacity="0"></stop>
        </radialGradient>
        <mask id="fade-mask">
          <ellipse cx="50%" cy="50%" rx="65%" ry="55%" fill="url(#oval-fade)"></ellipse>
        </mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid-pattern)" mask="url(#fade-mask)"></rect>
    </svg>
  </div>

  <div class="site-container relative z-10 py-16 md:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <div data-mos="fade-up" data-mos-anchor="#download">
        <h1
          class="mb-6 text-5xl leading-tight font-medium tracking-tight text-pretty md:text-6xl md:leading-tight"
        >
          {title}
        </h1>
      </div>

      <p
        class="description mb-10 text-pretty lg:text-lg"
        data-mos="fade-up"
        data-mos-delay=".1"
        data-mos-anchor="#download"
      >
        {description}
      </p>

      <div
        data-mos="fade-up"
        data-mos-delay=".2"
        data-mos-anchor="#download"
        class="flex flex-col items-center gap-5"
      >
        <Button
          variant="primary"
          href={macUrl}
          id="download-btn"
          data-win-url={winUrl}
          data-mac-url={macUrl}
          class="px-8 py-3 text-lg"
        >
          <Icon name="tabler/download" id="hero-icon-default" class="mr-2 size-5" />
          <Icon name="tabler/brand-apple" id="hero-icon-apple" class="mr-2 hidden size-5" />
          <Icon name="tabler/brand-windows" id="hero-icon-windows" class="mr-2 hidden size-5" />
          {t("download")}
          <span
            id="download-os"
            class="ml-1"
            data-windows={t("for_windows")}
            data-macos={t("for_macos")}
          >
          </span>
        </Button>

        <div id="hero-platform-links" class="flex items-center gap-6">
          <a
            href={macUrl}
            data-platform="mac"
            class="text-muted-foreground hover:text-foreground flex items-center gap-1.5 text-sm transition-colors"
          >
            <Icon name="tabler/brand-apple" class="size-4" />
            macOS
          </a>
          <a
            href={winUrl}
            data-platform="windows"
            class="text-muted-foreground hover:text-foreground flex items-center gap-1.5 text-sm transition-colors"
          >
            <Icon name="tabler/brand-windows" class="size-4" />
            Windows
          </a>
        </div>

        <a
          href="https://github.com/SoluDevTech/unispace-releases/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground hover:text-foreground inline-flex items-center gap-1 text-xs transition-colors"
        >
          <Icon name="tabler/external-link" class="size-3" />
          {t("all_versions")}
        </a>
      </div>

      <!-- Video Preview -->
      <div class="mt-12" data-mos="fade-up" data-mos-delay=".3" data-mos-anchor="#download">
        <div
          id="hero-video-preview"
          class="group border-border relative cursor-pointer overflow-hidden rounded-xl border shadow-lg transition-shadow hover:shadow-xl"
        >
          <video
            src="/videos/unispace-v3.mp4"
            muted
            autoplay
            loop
            playsinline
            class="aspect-video w-full object-cover"></video>
          <div
            class="absolute inset-0 flex items-center justify-center bg-black/20 transition-colors group-hover:bg-black/10"
          >
            <div
              class="flex size-14 items-center justify-center rounded-full bg-white/90 shadow-md transition-transform group-hover:scale-110"
            >
              <Icon name="tabler/player-play" class="ml-0.5 size-6 text-black" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Video Lightbox -->
<div id="hero-video-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center">
  <div
    id="hero-video-backdrop"
    class="absolute inset-0 bg-black/80 opacity-0 transition-opacity duration-300"
  >
  </div>
  <div id="hero-video-container" class="relative z-10 transition-all duration-500 ease-out">
    <video
      id="hero-video-expanded"
      src="/videos/unispace-v3.mp4"
      controls
      playsinline
      class="h-full w-full rounded-lg object-contain shadow-2xl"></video>
    <button
      id="hero-video-close"
      class="hover:bg-card bg-background text-foreground absolute -top-4 -right-4 flex size-8 items-center justify-center rounded-full shadow-md transition-colors"
      aria-label="Close video"
    >
      <Icon name="tabler/x" class="size-6" />
    </button>
  </div>
</div>

<script>
  function setupOsDetection() {
    const platform = navigator.platform?.toLowerCase() ?? "";
    const userAgent = navigator.userAgent?.toLowerCase() ?? "";
    const isMac = platform.includes("mac") || userAgent.includes("macintosh");
    const isWindows = platform.includes("win") || userAgent.includes("windows");

    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    if (!btn) return;

    if (isWindows) {
      btn.href = btn.dataset.winUrl ?? btn.href;
    } else if (isMac) {
      btn.href = btn.dataset.macUrl ?? btn.href;
    }

    const osSpan = document.getElementById("download-os");
    if (osSpan) {
      if (isWindows) osSpan.textContent = osSpan.dataset.windows ?? "";
      else if (isMac) osSpan.textContent = osSpan.dataset.macos ?? "";
    }

    const iconDefault = document.getElementById("hero-icon-default");
    const iconApple = document.getElementById("hero-icon-apple");
    const iconWindows = document.getElementById("hero-icon-windows");

    if (isMac && iconDefault && iconApple) {
      iconDefault.classList.add("hidden");
      iconApple.classList.remove("hidden");
    } else if (isWindows && iconDefault && iconWindows) {
      iconDefault.classList.add("hidden");
      iconWindows.classList.remove("hidden");
    }

    const links = document.getElementById("hero-platform-links");
    if (!links) return;

    const activeLink = isWindows
      ? links.querySelector<HTMLElement>('[data-platform="windows"]')
      : isMac
        ? links.querySelector<HTMLElement>('[data-platform="mac"]')
        : null;

    if (activeLink) {
      activeLink.classList.remove("text-muted-foreground");
      activeLink.classList.add("text-primary-accent", "font-medium");
    }
  }

  setupOsDetection();
  document.addEventListener("astro:after-swap", setupOsDetection);
</script>

<script>
  import { animate } from "motion";

  function setupVideoLightbox() {
    const preview = document.getElementById("hero-video-preview");
    const lightbox = document.getElementById("hero-video-lightbox") as HTMLDivElement | null;
    const backdrop = document.getElementById("hero-video-backdrop") as HTMLDivElement | null;
    const container = document.getElementById("hero-video-container") as HTMLDivElement | null;
    const expandedVideo = document.getElementById("hero-video-expanded") as HTMLVideoElement | null;
    const closeBtn = document.getElementById("hero-video-close");

    if (!preview || !lightbox || !backdrop || !container || !expandedVideo || !closeBtn) return;

    if (lightbox.parentElement !== document.body) {
      document.body.appendChild(lightbox);
    }

    const openLightbox = () => {
      const rect = preview.getBoundingClientRect();
      const videoRatio = 16 / 9;

      const maxWidth = window.innerWidth * 0.9;
      const maxHeight = window.innerHeight * 0.9;
      let targetWidth: number;
      let targetHeight: number;

      if (maxWidth / videoRatio <= maxHeight) {
        targetWidth = maxWidth;
        targetHeight = maxWidth / videoRatio;
      } else {
        targetHeight = maxHeight;
        targetWidth = maxHeight * videoRatio;
      }

      const targetTop = (window.innerHeight - targetHeight) / 2;
      const targetLeft = (window.innerWidth - targetWidth) / 2;

      Object.assign(container.style, {
        position: "fixed",
        top: `${rect.top}px`,
        left: `${rect.left}px`,
        width: `${rect.width}px`,
        height: `${rect.height}px`,
        zIndex: "100",
      });

      lightbox.classList.replace("hidden", "flex");
      backdrop.style.opacity = "1";
      preview.style.opacity = "0";

      expandedVideo.currentTime = 0;
      expandedVideo.play();

      animate(
        container,
        {
          top: [rect.top, targetTop],
          left: [rect.left, targetLeft],
          width: [rect.width, targetWidth],
          height: [rect.height, targetHeight],
        },
        { duration: 0.4, ease: "easeInOut" },
      );
    };

    const closeLightbox = async () => {
      const rect = preview.getBoundingClientRect();

      backdrop.style.opacity = "0";
      expandedVideo.pause();

      await animate(
        container,
        {
          top: rect.top,
          left: rect.left,
          width: rect.width,
          height: rect.height,
        },
        { duration: 0.4, ease: "easeInOut" },
      ).finished;

      preview.style.opacity = "1";
      lightbox.classList.replace("flex", "hidden");
      container.removeAttribute("style");
    };

    preview.addEventListener("click", openLightbox);
    closeBtn.addEventListener("click", closeLightbox);

    backdrop.addEventListener("click", closeLightbox);

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.classList.contains("hidden")) {
        closeLightbox();
      }
    });
  }

  setupVideoLightbox();
  document.addEventListener("astro:after-swap", setupVideoLightbox);
</script>
